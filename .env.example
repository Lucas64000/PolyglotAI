# ========================================
# APPLICATION SETTINGS
# ========================================
APP_NAME=PolyglotAI
DEBUG=false

# ========================================
# NEO4J DATABASE CONFIGURATION
# ========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password_here

# ========================================
# AI PROVIDER CONFIGURATION
# ========================================
# Choose your AI provider: "azure", "openai", or "ollama"
AI_PROVIDER=azure

# ========================================
# OPENAI SETTINGS (if AI_PROVIDER=openai)
# ========================================
AI_OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_CHAT_MODEL=gpt-4o-mini
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ========================================
# AZURE OPENAI SETTINGS (if AI_PROVIDER=azure)
# ========================================
AI_AZURE_API_KEY=your_azure_api_key_here
AI_AZURE_ENDPOINT=https://your-resource-name.openai.azure.com/
AI_AZURE_API_VERSION=2025-01-01-preview
AI_AZURE_CHAT_DEPLOYMENT=your-chat-deployment-name
AI_AZURE_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# ========================================
# OLLAMA SETTINGS (if AI_PROVIDER=ollama)
# ========================================
AI_OLLAMA_BASE_URL=http://localhost:11434
AI_OLLAMA_CHAT_MODEL=qwen2.5:7b
AI_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
