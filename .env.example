# Clé API AzureAIFoundry
AZURE_OPENAI_API_KEY=cle_api_azure

# Endpoint du déploiement du modèle AzureAIFoundy
AZURE_OPENAI_ENDPOINT=https://nom-ressource.openai.azure.com/

